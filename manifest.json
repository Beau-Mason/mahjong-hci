{
  "manifest_version": 3,
  "name": "Mahjong Soul Reflection (研究用プロトタイプ)",
  "version": "0.2.0",
  "description": "対局終了後に自身の表情を撮影し、内省を促すフィードバックを表示する研究用拡張機能。",
  "permissions": ["storage"],
  "host_permissions": ["https://game.mahjongsoul.com/*"],
  "content_scripts": [
    {
      "matches": ["https://game.mahjongsoul.com/*"],
      "js": ["src/ws-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://game.mahjongsoul.com/*"],
      "js": ["vendor/face-api.min.js", "src/content.js"],
      "css": ["src/modal.css"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/modal.css", "models/*"],
      "matches": ["https://game.mahjongsoul.com/*"]
    }
  ]
}
